# Application Config
NODE_ENV=development
APP_NAME=Resto ERP
APP_PORT=3000
APP_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d

# Database Configuration
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=resto_mvp
DB_SYNC=false
DB_LOGGING=true
DB_CONNECTION_LIMIT=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Configuration
API_RESPONSE_CACHE_TTL=3600

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Features
ENABLE_WEBSOCKET=true
ENABLE_SCHEDULER=true
ENABLE_SYNC=false
